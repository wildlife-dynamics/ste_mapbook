{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Set workflow details"
    },
    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "The start time"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "The end time"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        },
        "time_format": {
          "default": "%d %b %Y %H:%M:%S",
          "title": "Time Format",
          "type": "string",
          "description": "The time format",
          "ecoscope:advanced": true
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Define analysis time range"
    },
    "Set previous period range": {
      "type": "object",
      "description": "Define the previous period for comparison. By default, it will match the current period, but you can choose predefined options like \"Previous month\" or \"Previous year\", or specify a custom range.",
      "ecoscope:task_group": true,
      "properties": {
        "set_previous_period": {
          "additionalProperties": false,
          "properties": {
            "option": {
              "anyOf": [
                {
                  "$ref": "#/$defs/PreviousCustomTimeRangeOption"
                },
                {
                  "$ref": "#/$defs/PreviousTimeRangeOption"
                }
              ],
              "title": "Option",
              "default": {
                "custom": "Same as current period"
              }
            }
          },
          "required": [
            "option"
          ],
          "type": "object",
          "title": ""
        }
      }
    },
    "er_client_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/EarthRangerConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Connect to earth ranger"
    },
    "gee_project_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/GoogleEarthEngineConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Connect to earth engine"
    },
    "Subject Group": {
      "type": "object",
      "description": "Choose subject group to analyze",
      "ecoscope:task_group": true,
      "properties": {
        "subject_group_var": {
          "additionalProperties": false,
          "properties": {
            "var": {
              "title": "Subject Group Name",
              "type": "string",
              "default": "Elephants",
              "description": "Enter the subject group name exactly as it appears in EarthRanger (case-sensitive)."
            }
          },
          "required": [
            "var"
          ],
          "type": "object",
          "title": ""
        }
      }
    },
    "Load landDx database": {
      "type": "object",
      "description": "Load the landDx geodatabase and prepare it for mapping. The geodatabase will be filtered to include only protected areas (Community Conservancies, National Reserves, National Parks) and styled for visualization.",
      "ecoscope:task_group": true,
      "properties": {
        "retrieve_ldx_db": {
          "additionalProperties": false,
          "properties": {
            "input_method": {
              "anyOf": [
                {
                  "$ref": "#/$defs/DownloadFile"
                },
                {
                  "$ref": "#/$defs/LocalFile"
                }
              ],
              "title": "Input Method",
              "default": {
                "url": "https://www.dropbox.com/scl/fi/v9maw2jeg1zptv68qtpv3/landDx.gpkg?rlkey=kez5vsbxkgha2emfy5kzwa5n1&st=98v4anq3&dl=0"
              }
            }
          },
          "required": [
            "input_method"
          ],
          "type": "object",
          "title": ""
        }
      }
    },
    "Trajectory Segment Filter": {
      "type": "object",
      "description": "Filter trajectory segments based on criteria like minimum/maximum length, duration and speed. This helps remove GPS noise and unrealistic movements. The same filter will be applied to both current and previous trajectories to ensure consistency in the analysis.",
      "ecoscope:task_group": true,
      "properties": {
        "custom_trajs_filter": {
          "additionalProperties": false,
          "properties": {
            "min_length_meters": {
              "default": 0.001,
              "title": "Minimum Segment Length (m)",
              "type": "number",
              "description": "Discard segments shorter than this distance. Helps remove GPS noise and stationary fixes."
            },
            "max_length_meters": {
              "default": 5000,
              "title": "Maximum Segment Length (m)",
              "type": "number",
              "description": "Discard segments longer than this distance. Helps remove unrealistic long-distance jumps."
            },
            "min_time_secs": {
              "default": 1,
              "title": "Minimum Segment Duration (s)",
              "type": "number",
              "description": "Discard segments with a duration shorter than this (in seconds)."
            },
            "max_time_secs": {
              "default": 21600,
              "title": "Maximum Segment Duration (s)",
              "type": "number",
              "description": "Discard segments with a duration longer than this (in seconds). Default is 6 hours (21,600 s)."
            },
            "min_speed_kmhr": {
              "default": 0.01,
              "title": "Minimum Speed (km/h)",
              "type": "number",
              "description": "Discard segments where average speed falls below this value."
            },
            "max_speed_kmhr": {
              "default": 9.0,
              "title": "Maximum Speed (km/h)",
              "type": "number",
              "description": "Discard segments where average speed exceeds this value. For elephants, 9 km/h is a sensible ceiling."
            }
          },
          "type": "object",
          "required": [],
          "title": ""
        }
      }
    },
    "Zoom to gdf extent": {
      "type": "object",
      "description": "Calculate the geographic extent of the movement tracks and determine an appropriate zoom level and center point for the map. This ensures that all tracks are visible and well-framed when the map is rendered.",
      "ecoscope:task_group": true,
      "properties": {
        "zoom_to_envelope": {
          "additionalProperties": false,
          "properties": {
            "expansion_factor": {
              "default": 1.05,
              "title": "Expansion Factor",
              "type": "number",
              "description": "Adds padding around the map boundary. 1.0 = tight fit, 1.05 = 5% padding (default), 1.2 = 20% padding."
            }
          },
          "required": [],
          "type": "object",
          "title": ""
        }
      }
    },
    "Report logo": {
      "type": "object",
      "description": "Download or fetch the logo to be used in the report cover page. This task can be customized to fetch logos from different sources based on user requirements.",
      "ecoscope:task_group": true,
      "properties": {
        "logo_path": {
          "additionalProperties": false,
          "properties": {
            "input_method": {
              "anyOf": [
                {
                  "$ref": "#/$defs/DownloadFile"
                },
                {
                  "$ref": "#/$defs/LocalFile"
                }
              ],
              "title": "Input Method",
              "description": "Provide the organization logo to display on the report cover page (PNG or JPG recommended)."
            }
          },
          "required": [
            "input_method"
          ],
          "type": "object",
          "title": ""
        }
      }
    }
  },
  "$defs": {
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "PreviousCustomTimeRangeOption": {
      "description": "User selects a predefined previous period via the enum.",
      "properties": {
        "custom": {
          "allOf": [
            {
              "$ref": "#/$defs/PreviousPeriodType"
            }
          ],
          "description": "Select the previous period type"
        }
      },
      "required": [
        "custom"
      ],
      "title": "Choose which period you'd like to select your date from",
      "type": "object"
    },
    "PreviousPeriodType": {
      "description": "Enum for previous period selection options.",
      "enum": [
        "Same as current period",
        "Previous month",
        "Previous 3 months",
        "Previous 6 months",
        "Previous year"
      ],
      "title": "PreviousPeriodType",
      "type": "string"
    },
    "PreviousTimeRange": {
      "description": "Manual previous period selection.\n\nOnly `since` is provided by the user. `until` is always derived\nfrom the current period's start when converting to a TimeRange,\nenforcing the invariant that the previous period ends exactly\nwhere the current one begins.",
      "properties": {
        "since": {
          "description": "The start time of the previous period",
          "format": "date-time",
          "title": "Since",
          "type": "string"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": {
            "label": "UTC",
            "tzCode": "UTC",
            "name": "UTC",
            "utc": "+00:00"
          },
          "description": "Timezone (defaults to UTC)"
        },
        "time_format": {
          "default": "%d %b %Y %H:%M:%S",
          "description": "The time format",
          "title": "Time Format",
          "type": "string"
        }
      },
      "required": [
        "since"
      ],
      "title": "PreviousTimeRange",
      "type": "object"
    },
    "PreviousTimeRangeOption": {
      "description": "User manually specifies a start date for the previous period.",
      "properties": {
        "time_range": {
          "$ref": "#/$defs/PreviousTimeRange"
        }
      },
      "required": [
        "time_range"
      ],
      "title": "Enter the start date you'd like the previous period to begin from",
      "type": "object"
    },
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "GoogleEarthEngineConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "GoogleEarthEngineConnection",
      "type": "object"
    },
    "DownloadFile": {
      "properties": {
        "url": {
          "description": "URL to download a file",
          "title": "URL",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "title": "Download from URL",
      "type": "object"
    },
    "LocalFile": {
      "properties": {
        "file_path": {
          "description": "Path to a local file",
          "title": "Local file path",
          "type": "string"
        }
      },
      "required": [
        "file_path"
      ],
      "title": "Use local file",
      "type": "object"
    },
    "ValueGrouper": {
      "properties": {
        "index_name": {
          "oneOf": [
            {
              "const": "subject_name",
              "title": "Subject Name"
            },
            {
              "const": "subject_sex",
              "title": "Subject Sex"
            },
            {
              "const": "subject_subtype",
              "title": "Subject Subtype"
            }
          ]
        }
      }
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "time_range": {
      "ui:order": [
        "since",
        "until",
        "timezone",
        "time_format"
      ]
    },
    "Trajectory Segment Filter": {
      "custom_trajs_filter": {
        "ui:order": [
          "min_length_meters",
          "max_length_meters",
          "min_time_secs",
          "max_time_secs",
          "min_speed_kmhr",
          "max_speed_kmhr"
        ]
      }
    },
    "ui:order": [
      "workflow_details",
      "time_range",
      "Set previous period range",
      "er_client_name",
      "gee_project_name",
      "Subject Group",
      "Load landDx database",
      "Trajectory Segment Filter",
      "Zoom to gdf extent",
      "Report logo"
    ]
  },
  "additionalProperties": false
}
